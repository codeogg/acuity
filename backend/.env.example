# ============ 前端 ============
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ============ 后端 ============
# 数据库（SQLAlchemy async 驱动 asyncpg）
# 使用 docker compose 时 postgres 映射到本机 5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/insurance
# Redis（缓存 + arq broker + 限流）
REDIS_URL=redis://localhost:6379/0

# JWT 会话密钥（生产请使用强随机值）
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=8

# 病历文本字段级加密密钥（Fernet key，base64，32 字节）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
# MFA TOTP 密钥 AES 加密（Fernet；留空则 local 环境自动生成临时密钥）
MFA_ENCRYPTION_KEY=

# 对象存储（S3 协议兼容：AWS S3 / MinIO / 阿里 OSS / 腾讯 COS）
S3_BUCKET=insurance
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000/insurance

# Google Vertex AI - Gemini
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=europe-west2
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# 通用（理赔 AI 辅助等非流水线模块）
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-pro-preview

# Step4 文档分类：Gemini 2.5 Flash @ europe-west2
GEMINI_CLASSIFIER_MODEL=gemini-2.5-flash
GEMINI_CLASSIFIER_LOCATION=europe-west2

# Step5 多就诊检测：默认同 Step4
GEMINI_VISIT_DETECTOR_MODEL=gemini-2.5-flash
GEMINI_VISIT_DETECTOR_LOCATION=europe-west2

# Step7 字段提取：Gemini 3.1 Pro Preview @ global
GEMINI_EXTRACTOR_MODEL=gemini-3.1-pro-preview
GEMINI_EXTRACTOR_LOCATION=global
# Step7 thinking 级别：low（默认）/ medium / high
GEMINI_EXTRACTOR_THINKING_LEVEL=low

# AI 限流：每诊所每分钟最大调用次数
AI_RATE_LIMIT_PER_MINUTE=20

# 运行环境：local / production
APP_ENV=local
# local 环境下 Gemini 429/503 会自动降级 stub；生产可显式开启
# GEMINI_STUB_ON_ERROR=true
# 允许跨域来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000
