# ============================================================
# 生产环境变量模板 — 复制为 .env 后填入真实值
# cp .env.production.example .env
# ============================================================

# ---------- 对外访问（必填）----------
# 用户浏览器访问的完整地址，须含 https://，末尾不要斜杠
PUBLIC_BASE_URL=https://your-domain.com

# ---------- 前端（web 容器）----------
# 浏览器看到的 API 根地址；走 Nginx 同源反代时填 PUBLIC_BASE_URL 即可
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com
# 容器内 Next.js 转发 /api 到后端（Docker 内网服务名）
API_PROXY_TARGET=http://api:8000

# ---------- 后端（api / worker 容器）----------
APP_ENV=production
CORS_ORIGINS=https://your-domain.com

DATABASE_URL=postgresql+asyncpg://insurance:CHANGE_DB_PASSWORD@postgres:5432/insurance
REDIS_URL=redis://redis:6379/0

# 生成：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRE_HOURS=8

# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# ---------- 对象存储 ----------
# 方案 A：同机 MinIO（默认 compose 已含 minio 服务）
S3_BUCKET=insurance
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_MINIO_SECRET_KEY
S3_REGION=us-east-1
# 对外 PDF/图片访问地址（经 Nginx 或 MinIO 公网域名）
S3_PUBLIC_BASE_URL=https://your-domain.com/storage

# 方案 B：云 OSS/COS/S3 — 替换上面 MinIO 相关项，并在 compose 中去掉 minio

# ---------- Google Vertex AI（AI 识别，可暂留空走 stub）----------
GCP_PROJECT_ID=
GCP_LOCATION=asia-east1
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-pro
AI_RATE_LIMIT_PER_MINUTE=20

# ---------- Postgres / MinIO 容器初始化（仅 compose 使用）----------
POSTGRES_USER=insurance
POSTGRES_PASSWORD=CHANGE_DB_PASSWORD
POSTGRES_DB=insurance
MINIO_ROOT_USER=CHANGE_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_MINIO_SECRET_KEY
