{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: FastAPI (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "src.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/apps/api",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Worker: arq",
      "type": "debugpy",
      "request": "launch",
      "module": "arq",
      "args": ["src.tasks.worker.WorkerSettings"],
      "cwd": "${workspaceFolder}/apps/api",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Web: Next.js dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Web: attach to Next.js",
      "type": "node",
      "request": "attach",
      "port": 9230,
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "全栈本地调试",
      "configurations": ["API: FastAPI (uvicorn)", "Web: Next.js dev server"],
      "stopAll": true,
      "presentation": {
        "group": "dev",
        "order": 1
      }
    },
    {
      "name": "全栈 + Worker",
      "configurations": [
        "API: FastAPI (uvicorn)",
        "Worker: arq",
        "Web: Next.js dev server"
      ],
      "stopAll": true,
      "presentation": {
        "group": "dev",
        "order": 2
      }
    }
  ]
}
