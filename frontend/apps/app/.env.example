# Copy to .env.local and fill values (never commit values).
#
# --- Mock-first (default) ---
# NEXT_PUBLIC_API_MOCKING=enabled
# NEXT_PUBLIC_API_BASE=/api
#
# --- Live local (FastAPI :8000, doctor app :3000) ---
# NEXT_PUBLIC_API_MOCKING=disabled
# NEXT_PUBLIC_API_BASE=/api
# API_PROXY_TARGET=http://localhost:8000
# SSR uses API_PROXY_TARGET/api automatically (see @acuity/api-client).

# Base URL for the typed api-client. Defaults to same-origin "/api" when unset.
NEXT_PUBLIC_API_BASE=/api

# Toggle MSW mock-first mode ("disabled" for live FastAPI).
NEXT_PUBLIC_API_MOCKING=enabled

# Real backend target for the same-origin /api/* proxy (live mode).
API_PROXY_TARGET=

# Console sign-in URL for the "operator console" cross-link on the doctor
# sign-in card (defaults to the local /sign-in path when unset).
NEXT_PUBLIC_CONSOLE_SIGN_IN_URL=

# Default mock scenario(s), comma-separated (e.g. "slow-network,ai-degrade").
# See packages/api-client/README.md for the canonical scenario names.
NEXT_PUBLIC_MOCK_SCENARIO=
