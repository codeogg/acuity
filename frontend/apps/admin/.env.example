# Admin console — local live mode (FastAPI on :8000, admin on :3002)
#
# Copy to .env.local and keep all three vars in sync:
#   cp .env.example .env.local
#
# NEXT_PUBLIC_API_MOCKING=disabled     — turn off MSW mocks
# NEXT_PUBLIC_API_BASE=/api            — browser same-origin (cookie + rewrite)
# API_PROXY_TARGET=http://localhost:8000 — Next.js rewrites /api/* → FastAPI
#
# SSR/Server Actions use API_PROXY_TARGET/api automatically (see @acuity/api-client).
# Optional explicit SSR override:
# API_SERVER_BASE=http://localhost:8000/api

NEXT_PUBLIC_API_MOCKING=
NEXT_PUBLIC_API_BASE=
API_PROXY_TARGET=
