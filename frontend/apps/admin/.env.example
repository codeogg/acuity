# Admin console environment (names only; no values are committed).
#
# NEXT_PUBLIC_API_MOCKING: "disabled" switches off the MSW mock data path
# (mock-first is the default; see next.config.ts).
# NEXT_PUBLIC_API_BASE: absolute API origin for live mode; defaults to the
# app's own origin in mock mode.
NEXT_PUBLIC_API_MOCKING=
NEXT_PUBLIC_API_BASE=
