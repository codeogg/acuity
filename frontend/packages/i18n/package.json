{
  "name": "@acuity/i18n",
  "version": "0.1.0",
  "private": true,
  "description": "Shared bilingual (en-HK / zh-Hant-HK) i18n foundation for the Acuity frontend: one routing definition, request-config and middleware factories, locale-aware navigation wrappers, and Intl formatting helpers.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./routing": {
      "types": "./src/routing.ts",
      "import": "./src/routing.ts"
    },
    "./request": {
      "types": "./src/request.ts",
      "import": "./src/request.ts"
    },
    "./middleware": {
      "types": "./src/middleware.ts",
      "import": "./src/middleware.ts"
    },
    "./navigation": {
      "types": "./src/navigation.ts",
      "import": "./src/navigation.ts"
    },
    "./names": {
      "types": "./src/names.ts",
      "import": "./src/names.ts"
    },
    "./format": {
      "types": "./src/format.ts",
      "import": "./src/format.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "next": ">=15",
    "next-intl": ">=4",
    "react": ">=19"
  },
  "devDependencies": {
    "@acuity/config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "next": "^15.2.0",
    "next-intl": "^4.13.0",
    "react": "^19.0.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.0"
  }
}
