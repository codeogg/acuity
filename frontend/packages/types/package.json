{
  "name": "@acuity/types",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript types generated from the canonical OpenAPI contract (openapi.json). snake_case field names are preserved to match the API exactly.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./openapi": {
      "types": "./src/generated/openapi.ts",
      "import": "./src/generated/openapi.ts"
    }
  },
  "files": [
    "src",
    "openapi.json"
  ],
  "scripts": {
    "generate": "openapi-typescript ./openapi.json -o ./src/generated/openapi.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@acuity/config": "workspace:*",
    "openapi-typescript": "^7.5.0",
    "typescript": "~5.9.2"
  }
}
