    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT access token. Takes precedence over the cookie when both are sent."
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token",
        "description": "httpOnly session cookie set by POST /api/auth/login (8h, samesite=lax; `secure` must be environment-driven in production)."
      }
    },
    "parameters": {
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Reserved. Not enforced in Phase 1; clients may send a unique key per logical mutation so later server-side enforcement is non-breaking."
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    },
    {
      "cookieAuth": []
    }
  ],
  "tags": [
    {
      "name": "auth",
      "description": "Session base ops (password sign-in per ADR 0040): login, logout, current user."
    },
    {
      "name": "admin:clinics",
      "description": "Clinic CRUD + per-clinic insurance-company and template enablement (operator console)."
    },
    {
      "name": "admin:doctors",
      "description": "Doctor account CRUD + password reset (operator console)."
    },
    {
      "name": "admin:insurance",
      "description": "Insurance-company CRUD + logo upload (operator console)."
    },
    {
      "name": "admin:standard-fields",
      "description": "Standard-field dictionary, field domains, and value transform rules."
    },
    {
      "name": "admin:templates",
      "description": "Form-template upload, parsing, field annotation, mapping, and publication."
    },
    {
      "name": "doctor:ai",
      "description": "Stateless AI extraction (per-clinic rate limit 20/min; 429 on breach, 503 when the AI provider is unavailable)."
    },
    {
      "name": "doctor:claims",
      "description": "Doctor claim workflow: home overview, catalogue, claim state machine, PDF generation."
    },
    {
      "name": "claim-extensions",
      "description": "Claim-scoped extensions: intake source evidence and history permanent-delete.",
      "x-backend-status-group": true
    },
    {
      "name": "system",
      "description": "Service liveness."
    },
    {
      "name": "coverage-registry",
      "description": "Covered-vs-roadmap insurer/form registry driving form selection; coverage must never be overstated.",
      "x-backend-status-group": true
    },
    {
      "name": "document-inbox",
      "description": "Virtual-printer captures and future upload channels awaiting intake import.",
      "x-backend-status-group": true
    },
    {
      "name": "staff-handoff",
      "description": "Staff-prepared claims handed to the doctor for review and sign-off.",
      "x-backend-status-group": true
    },
    {
      "name": "doctor-settings",
      "description": "Doctor account settings; the produce step consumes the signature image.",
      "x-backend-status-group": true
    },
    {
      "name": "notifications",
      "description": "In-app notifications for the doctor surface.",
      "x-backend-status-group": true
    },
    {
      "name": "support-access",
      "description": "Doctor-side grant/revoke seam for operator impersonation; every grant/session emits an audit event.",
      "x-backend-status-group": true
    },
    {
      "name": "auth-flow",
      "description": "Target-auth journey behind the frontend auth-adapter seam (ADRs 0040/0041): MFA, recovery, account discovery, clinic selection, session state, re-auth deep links.",
      "x-backend-status-group": true
    },
    {
      "name": "admin-audit",
      "description": "Operator audit trail (the backend's unwritten operation_log, wired). Surrogate-only fields, no PHI.",
      "x-backend-status-group": true
    },
    {
      "name": "admin-tickets",
      "description": "Operations tickets and the clinic onboarding queue.",
      "x-backend-status-group": true
    },
    {
      "name": "admin-tags",
      "description": "Form-tag taxonomy and the per-doctor visibility matrix.",
      "x-backend-status-group": true
    },
    {
      "name": "admin-analytics",
      "description": "Console analytics aggregates; exports are surrogate-only and audit-logged.",
      "x-backend-status-group": true
    },
    {
      "name": "admin-saved-views",
      "description": "Named filter+sort presets for the console ops grids.",
      "x-backend-status-group": true
    },
    {
      "name": "admin-impersonation",
      "description": "Operator-side impersonation sessions; server-rendered and fail-safe in production.",
      "x-backend-status-group": true
    },
    {
      "name": "admin-claims-oversight",
      "description": "Admin-scoped claims oversight (cross-clinic, PHI-redacted): the console must not ride doctor-scoped routes an admin token cannot call.",
      "x-backend-status-group": true
    },
    {
      "name": "account-management",
      "description": "ADR 0041 account-clinic management: link/unlink/switch, account-model fields, login-issue tooling, clinic notes.",
      "x-backend-status-group": true
    },
    {
      "name": "admin:audit",
      "description": "Unified operator audit trail (append-only, PHI-safe)."
    }
  ]
