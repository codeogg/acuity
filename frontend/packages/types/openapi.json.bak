                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Sort",
              "description": "Sort by name, code, status, doctors, or created_at; prefix - for descending."
            }
          },
          {
            "name": "is_flagged",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1,
              "title": "Is Flagged"
            },
            "description": "Filter by needs-attention flag: 1 = flagged only, 0 = unflagged only."
          }
        ],
        "responses": {
