            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        },
        "x-implementation-note": "Normalised to the typed SuccessResponse (the implemented backend returns an ad-hoc dict).",
        "security": []
      }
    },
