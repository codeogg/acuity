      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ],
        "description": "Uniform acknowledgement body for actions with no resource payload."
      },
      "ErrorCode": {
        "type": "string",
        "enum": [
          "APP_ERROR",
          "VALIDATION_ERROR",
          "NOT_FOUND",
          "CONFLICT",
          "UNAUTHORIZED",
          "FORBIDDEN",
          "RATE_LIMITED",
          "AI_UNAVAILABLE"
        ],
        "description": "Closed domain error-code list. Additions require a contract revision."
      },
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "$ref": "#/components/schemas/ErrorCode"
              },
              "message": {
                "type": "string",
                "description": "Display candidate only; may be Chinese. Clients own user-facing copy."
              },
              "request_id": {
                "type": "string",
                "description": "Optional correlation id for tracing. Servers should populate it once tracing lands."
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ],
        "description": "Domain error envelope for every non-2xx failure except request-shape validation, which keeps FastAPI's native 422 HTTPValidationError shape."
      },
      "FieldMappingSaveResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ],
        "description": "Saved mapping row id."
      },
      "ClaimStatus": {
        "type": "string",
        "enum": [
          "DRAFT",
          "AI_FILLED",
          "CONFIRMED",
          "PRINTED",
          "CANCELLED"
        ],
        "description": "Claim state machine: DRAFT -> AI_FILLED -> CONFIRMED -> PRINTED; CANCELLED reachable from any state."
      },
      "TemplateParseStatus": {
        "type": "string",
        "enum": [
          "PENDING",
          "PARSING",
          "AUTO_PARSED",
          "AI_ASSISTED",
          "ANNOTATED",
          "PUBLISHED",
          "PARSE_FAILED"
        ],
        "description": "Template parse/publication lifecycle."
      },
      "TemplateFieldStatus": {
        "type": "string",
        "enum": [
          "PENDING",
          "MAPPED",
          "IGNORED"
        ],
        "description": "Template-field mapping lifecycle."
      },
      "TemplateFieldType": {
        "type": "string",
        "enum": [
          "text",
          "checkbox",
          "radio",
          "signature",
          "image",
          "date"
        ]
      },
      "RecognizeSource": {
        "type": "string",
        "enum": [
          "AUTO_PDF",
          "AI_VISION",
          "MANUAL"
        ],
        "description": "How a template field was recognised."
      },
      "FieldDataType": {
        "type": "string",
        "enum": [
          "text",
          "number",
          "date",
          "boolean",
          "enum",
          "table",
          "image",
          "signature"
        ]
      },
      "FieldSourceType": {
        "type": "string",
        "enum": [
          "AI",
          "SYSTEM",
          "MANUAL"
        ],
        "description": "Where a standard field's value comes from."
      },
      "TransformRuleType": {
        "type": "string",
        "enum": [
          "DATE_FORMAT",
          "CONCAT",
          "SPLIT",
          "ENUM_MAP",
          "CUSTOM_SCRIPT"
        ]
      },
      "UserRole": {
        "type": "string",
        "enum": [
          "SUPER_ADMIN",
          "OPERATOR",
          "ANNOTATOR",
          "DOCTOR"
        ],
        "description": "Access is role-namespace based in Phase 1: the three admin roles are interchangeable for authorisation (sub-role separation is a backend follow-up); DOCTOR tokens carry clinic scope."
      },
      "WorkspaceSeparation": {
        "type": "string",
        "enum": [
          "separated",
          "merged"
        ],
        "description": "Multi-clinic workspace behaviour (ADR 0041 §6): `separated` picks a clinic per session; `merged` lands in one combined workspace."
      },
      "DoctorAccountOut": {
        "allOf": [
          {
            "$ref": "#/components/schemas/DoctorOut"
          },
          {
            "type": "object",
            "properties": {
              "clinic_ids": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              },
              "notes": {
                "type": "string",
                "description": "Operator-internal markdown notes - never doctor-visible."
              },
              "workspace_separation": {
                "$ref": "#/components/schemas/WorkspaceSeparation"
              },
              "mfa_enabled": {
                "type": "boolean"
              },
              "notes_format": {
                "type": "string",
                "enum": [
                  "markdown",
                  "html"
                ]
              }
            },
            "required": [
              "clinic_ids",
              "notes",
              "workspace_separation",
              "mfa_enabled",
              "notes_format"
            ]
          }
        ],
        "description": "DoctorOut plus the ADR 0041 account model: all linked clinics (empty = individual account; `clinic_id` stays the primary link for compatibility), operator notes, workspace behaviour, MFA opt-in."
      },
