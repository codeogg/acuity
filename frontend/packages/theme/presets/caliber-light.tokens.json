        },
        "md": {
          "$value": "0.625rem",
          "$description": "10px - buttons, inputs, small cards."
        },
        "lg": {
          "$value": "1rem",
          "$description": "16px - cards, panels, dialogs (boxed-canvas material, Fluence scale)."
        }
      },
      "container": {
