          "$value": "#8AA8C0"
        },
        "muted-iris": {
          "$value": "#8F89B7"
        },
        "dusty-rose": {
          "$value": "#DEBEC8"
        },
        "lavender-grey": {
          "$value": "#C4C7DB"
        },
        "dusty-lilac": {
          "$value": "#C5BDD5"
        },
        "soft-plum": {
          "$value": "#867A98"
        },
        "champagne": {
          "$value": "#E5DBCF"
        },
        "mist-lavender": {
