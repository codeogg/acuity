    "shadow": {
      "$type": "shadow",
      "$description": "Canonical elevation tiers - every box- or button-like element on every surface belongs to exactly one: FLAT (border only, no shadow token), CONTROL (sm - buttons, inputs, chips: a crisp 1px drop), RAISED (base/md - resting cards and panels: a soft close shadow plus a faint ambient one), OVERLAY (lg - popovers, dialogs, floating bars: a pronounced ambient shadow). Values follow the desktop-app soft-neutral school (hairline-plus-whisper shadows, never heavy blur on resting content).",
      "sm": {
        "$value": {
          "color": "rgba(10, 18, 42, 0.06)",
          "offsetX": "0rem",
          "offsetY": "0.0625rem",
          "blur": "0.125rem",
          "spread": "0rem"
        },
        "$description": "CONTROL tier - buttons, inputs, chips."
      },
      "base": {
        "$value": [
          {
            "color": "rgba(10, 18, 42, 0.04)",
            "offsetX": "0rem",
            "offsetY": "0.0625rem",
            "blur": "0.125rem",
            "spread": "0rem"
          },
          {
            "color": "rgba(10, 18, 42, 0.05)",
            "offsetX": "0rem",
            "offsetY": "0.25rem",
            "blur": "0.75rem",
            "spread": "0rem"
          }
        ],
        "$description": "RAISED tier - resting cards and panels."
      },
      "md": {
        "$value": [
          {
            "color": "rgba(10, 18, 42, 0.05)",
            "offsetX": "0rem",
            "offsetY": "0.125rem",
            "blur": "0.25rem",
            "spread": "0rem"
          },
          {
            "color": "rgba(10, 18, 42, 0.07)",
            "offsetX": "0rem",
            "offsetY": "0.5rem",
            "blur": "1rem",
            "spread": "0rem"
          }
        ],
        "$description": "RAISED-emphasis tier - hovered/prominent cards, the compact floating header."
      },
      "lg": {
        "$value": [
          {
            "color": "rgba(10, 18, 42, 0.06)",
            "offsetX": "0rem",
            "offsetY": "0.125rem",
            "blur": "0.5rem",
            "spread": "0rem"
          },
          {
            "color": "rgba(10, 18, 42, 0.14)",
            "offsetX": "0rem",
            "offsetY": "0.5rem",
            "blur": "1.875rem",
            "spread": "0rem"
          }
