          "$value": "#072052"
        },
        "ink": {
          "$value": "#0A122A"
        },
        "ink-muted": {
          "$value": "#5C6478"
        },
        "cream": {
          "$value": "#FFFEFD"
        },
        "cream-contrast": {
          "$value": "#FCFBF9"
        },
        "hover": {
          "$value": "#ECEFF4",
          "$description": "Interactive hover/selected surface - a perceptible step above cream. cream-contrast is intentionally near-invisible for resting fills, so it cannot double as hover feedback; this reads as a calm cool-neutral tint on the warm cream ground."
        },
        "border": {
          "$value": "#EAE6E0"
        },
        "border-strong": {
          "$value": "#DAD3CA"
        },
        "sky-blue": {
          "$value": "#C7D9E6"
        },
        "glaucous": {
          "$value": "#6082B6"
        },
        "venice-blue": {
          "$value": "#16587B"
        },
        "slate-blue": {
          "$value": "#629BB5"
        },
