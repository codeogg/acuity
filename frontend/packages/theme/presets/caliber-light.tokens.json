        "navy-deep": {
          "$value": "#04153a",
          "$description": "Darkened navy (pressed/active step; superseded as the HOVER step by navy-bright - hover now lightens, per the perceptible-lift feedback rule)."
        },
        "navy-bright": {
          "$value": "#16387E",
          "$description": "Brightened navy - the primary-action HOVER step. Hover lightens rather than darkens so the state change is perceptible on the dark navy fill (cream text stays ~10:1)."
        },
        "cranberry-deep": {
          "$value": "#b4566d",
          "$description": "Darkened cranberry for the destructive-action hover step."
        },
        "venice-blue-deep": {
          "$value": "#0f425e",
          "$description": "Deepened venice-blue for the link-hover step."
        },
        "pale-gold-deep": {
          "$value": "#9C8A3E",
